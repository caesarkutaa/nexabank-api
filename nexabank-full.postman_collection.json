{
  "info": {
    "name": "NexaBank — Complete API (A to Z)",
    "description": "Full end-to-end test collection for NexaBank banking system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base",      "value": "http://localhost:3001/api/v1" },
    { "key": "token",     "value": "" },
    { "key": "userId",    "value": "" },
    { "key": "accountId", "value": "" },
    { "key": "cardId",    "value": "" },
    { "key": "loanId",    "value": "" },
    { "key": "txId",      "value": "" },
    { "key": "investId",  "value": "" },
    { "key": "chequeId",  "value": "" }
  ],
  "item": [
    {
      "name": "01 🔐 AUTH",
      "item": [
        {
          "name": "01 Generate Captcha",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "if(r.data?.code) pm.collectionVariables.set('captcha', r.data.code);",
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has code', () => pm.expect(r.data.code).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base}}/auth/captcha/generate"
          }
        },
        {
          "name": "02 Register",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "pm.test('Status 201', () => pm.response.to.have.status(201));",
                "pm.test('Has message', () => pm.expect(r.data.message).to.include('Registration'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_nexabank\",\n  \"email\": \"john.nexabank@gmail.com\",\n  \"password\": \"SecurePass@123\",\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phoneNumber\": \"+12125551234\",\n  \"dateOfBirth\": \"1990-05-15\"\n}"
            },
            "url": "{{base}}/auth/register"
          }
        },
        {
          "name": "03 Verify Email (paste OTP from email)",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"otp\": \"PASTE_OTP_HERE\"\n}"
            },
            "url": "{{base}}/auth/verify-email"
          }
        },
        {
          "name": "04 Resend OTP",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"email\": \"john.nexabank@gmail.com\"\n}"
            },
            "url": "{{base}}/auth/resend-otp"
          }
        },
        {
          "name": "05 Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "if(r.data?.accessToken){",
                "  pm.collectionVariables.set('token', r.data.accessToken);",
                "  pm.collectionVariables.set('userId', r.data.user?.id ?? '');",
                "}",
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "pm.test('Has accessToken', () => pm.expect(r.data.accessToken).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"john_nexabank\",\n  \"password\": \"SecurePass@123\",\n  \"captchaCode\": \"{{captcha}}\",\n  \"captchaToken\": \"{{captcha}}\"\n}"
            },
            "url": "{{base}}/auth/login"
          }
        },
        {
          "name": "06 Setup 2FA",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "const r = pm.response.json();",
                "if(r.data?.secret) pm.collectionVariables.set('twoFaSecret', r.data.secret);",
                "pm.test('Has QR code', () => pm.expect(r.data.qrCode).to.be.a('string'));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/auth/2fa/setup"
          }
        },
        {
          "name": "07 Enable 2FA (scan QR in Google Authenticator first)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_6_DIGIT_TOTP_HERE\"\n}"
            },
            "url": "{{base}}/auth/2fa/enable"
          }
        },
        {
          "name": "08 Verify 2FA",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"token\": \"PASTE_6_DIGIT_TOTP_HERE\"\n}"
            },
            "url": "{{base}}/auth/2fa/verify"
          }
        },
        {
          "name": "09 Set Security PIN",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200 or 201', () => pm.expect(pm.response.code).to.be.oneOf([200,201]));"
              ]
            }
          }],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pin\": \"123456\"\n}"
            },
            "url": "{{base}}/auth/security-pin/set"
          }
        },
        {
          "name": "10 Verify Security PIN",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pin\": \"123456\"\n}"
            },
            "url": "{{base}}/auth/security-pin/verify"
          }
        }
      ]
    },
    {
      "name": "02 👤 USERS",
      "item": [
        {
          "name": "01 Get Profile",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const r = pm.response.json();",
                "pm.test('Has username', () => pm.expect(r.data.username).to.eql('john_nexabank'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/users/profile"
          }
        },
        {
          "name": "02 Update Profile",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const r = pm.response.json();",
                "pm.test('Address updated', () => pm.expect(r.data.city).to.eql('New York'));"
              ]
            }
          }],
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Authorization", "value": "Bearer {{token}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"phoneNumber\": \"+12125551234\",\n  \"address\": \"123 Main Street\",\n  \"city\": \"New York\",\n  \"state\": \"NY\",\n  \"zipCode\": \"10001\"\n}"
            },
            "url": "{{base}}/users/profile"
          }
        },
        {
          "name": "03 Upload Profile Picture (attach image file)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "file", "type": "file", "src": "", "description": "Select any JPG/PNG image" }
              ]
            },
            "url": "{{base}}/users/profile/picture"
          }
        }
      ]
    },
