    {
      "name": "05 📋 TRANSACTIONS",
      "item": [
        {
          "name": "01 Get All Transactions",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status 200', () => pm.response.to.have.status(200));",
                "const r = pm.response.json();",
                "if(r.data?.transactions?.[0]?._id) pm.collectionVariables.set('txId', r.data.transactions[0]._id);",
                "pm.test('Has pagination', () => pm.expect(r.data.pagination).to.be.an('object'));"
              ]
            }
          }],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": {
              "raw": "{{base}}/transactions?page=1&limit=10",
              "query": [
                { "key": "page",      "value": "1"    },
                { "key": "limit",     "value": "10"   },
                { "key": "direction", "value": "debit", "disabled": true },
                { "key": "status",    "value": "completed", "disabled": true },
                { "key": "type",      "value": "intrabank_transfer", "disabled": true }
              ]
            }
          }
        },
