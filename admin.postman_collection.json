{
  "info": {
    "name": "NexaBank — Admin Panel",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base",      "value": "http://localhost:3001/api/v1" },
    { "key": "token",     "value": "" },
    { "key": "userId",    "value": "" },
    { "key": "accountId", "value": "" },
    { "key": "loanId",    "value": "" },
    { "key": "kycId",     "value": "" },
    { "key": "chequeId",  "value": "" },
    { "key": "txId",      "value": "" },
    { "key": "investId",  "value": "" }
  ],
  "item": [
    {
      "name": "00 🔐 Admin Login",
      "event": [{ "listen": "test", "script": { "exec": [
        "const r = pm.response.json();",
        "if(r.data?.accessToken) pm.collectionVariables.set('token', r.data.accessToken);"
      ]}}],
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": { "mode": "raw", "raw": "{\n  \"username\": \"superadmin\",\n  \"password\": \"AdminPass@123\",\n  \"captchaCode\": \"SKIP\",\n  \"captchaToken\": \"SKIP\"\n}" },
        "url": "{{base}}/auth/login"
      }
    },
    {
      "name": "01 📊 Dashboard",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
        "url": "{{base}}/admin/dashboard"
      }
    },
    {
      "name": "02 👥 USERS",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/admin/users?page=1&limit=20", "query": [
              { "key": "page",   "value": "1"  },
              { "key": "limit",  "value": "20" },
              { "key": "status", "value": "active", "disabled": true },
              { "key": "search", "value": "john",   "disabled": true }
            ]}
          }
        },
        {
          "name": "Get User Details",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if(r.data?.user?._id) pm.collectionVariables.set('userId', r.data.user._id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/users/{{userId}}"
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"test_user_01\",\n  \"email\": \"testuser01@nexabank.com\",\n  \"password\": \"SecurePass@123\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"User\",\n  \"phoneNumber\": \"+12125559999\",\n  \"role\": \"user\",\n  \"skipEmailVerification\": true\n}" },
            "url": "{{base}}/admin/users"
          }
        },
        {
          "name": "Block User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Suspicious activity detected\"\n}" },
            "url": "{{base}}/admin/users/{{userId}}/block"
          }
        },
        {
          "name": "Unblock User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/users/{{userId}}/unblock"
          }
        },
        {
          "name": "Update Credit Score",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"score\": 720,\n  \"rating\": \"good\"\n}" },
            "url": "{{base}}/admin/users/{{userId}}/credit-score"
          }
        }
      ]
    },
    {
      "name": "03 🏦 ACCOUNTS",
      "item": [
        {
          "name": "Get All Accounts",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if(r.data?.accounts?.[0]?._id) pm.collectionVariables.set('accountId', r.data.accounts[0]._id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/admin/accounts?page=1&limit=20", "query": [
              { "key": "page", "value": "1" },
              { "key": "status", "value": "frozen", "disabled": true }
            ]}
          }
        },
        {
          "name": "Create Account for User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"accountType\": \"savings\",\n  \"initialDeposit\": 1000,\n  \"nickname\": \"Admin Created Savings\"\n}" },
            "url": "{{base}}/admin/accounts"
          }
        },
        {
          "name": "Freeze Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/accounts/{{accountId}}/freeze"
          }
        },
        {
          "name": "Unfreeze Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/accounts/{{accountId}}/unfreeze"
          }
        },
        {
          "name": "Credit User Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 5000,\n  \"type\": \"credit\",\n  \"reason\": \"Promotional bonus credit\"\n}" },
            "url": "{{base}}/admin/accounts/credit-debit"
          }
        },
        {
          "name": "Debit User Account",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"accountId\": \"{{accountId}}\",\n  \"amount\": 100,\n  \"type\": \"debit\",\n  \"reason\": \"Chargeback reversal\"\n}" },
            "url": "{{base}}/admin/accounts/credit-debit"
          }
        }
      ]
    },
    {
      "name": "04 💸 TRANSACTIONS",
      "item": [
        {
          "name": "Get All Transactions",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if(r.data?.transactions?.[0]?._id) pm.collectionVariables.set('txId', r.data.transactions[0]._id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/admin/transactions?page=1&limit=20", "query": [
              { "key": "page",   "value": "1"   },
              { "key": "limit",  "value": "20"  },
              { "key": "status", "value": "pending", "disabled": true },
              { "key": "search", "value": "NXB",     "disabled": true }
            ]}
          }
        },
        {
          "name": "Edit Transaction (amount, date, status, recipient)",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"status\": \"completed\",\n  \"amount\": 450.00,\n  \"description\": \"Updated transfer description\",\n  \"recipientName\": \"Jane Smith Updated\",\n  \"processedAt\": \"2024-06-15T10:30:00.000Z\",\n  \"adminNotes\": \"Manually updated by admin\"\n}" },
            "url": "{{base}}/admin/transactions/{{txId}}"
          }
        },
        {
          "name": "Block Transfer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"transactionId\": \"{{txId}}\",\n  \"reason\": \"Flagged for fraud investigation\"\n}" },
            "url": "{{base}}/admin/transactions/block"
          }
        },
        {
          "name": "Unblock Transfer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/transactions/{{txId}}/unblock"
          }
        },
        {
          "name": "Edit Receipt",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"description\": \"Corrected transfer receipt\",\n  \"recipientName\": \"Correct Name LLC\",\n  \"amount\": 1500.00,\n  \"fee\": 5.00,\n  \"status\": \"completed\",\n  \"processedAt\": \"2024-06-20T14:00:00.000Z\"\n}" },
            "url": "{{base}}/admin/transactions/{{txId}}/receipt"
          }
        }
      ]
    },
    {
      "name": "05 🏛️ LOANS",
      "item": [
        {
          "name": "Get All Loans (Pending Review)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if(r.data?.loans?.[0]?._id) pm.collectionVariables.set('loanId', r.data.loans[0]._id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/admin/loans?status=under_review", "query": [
              { "key": "status", "value": "under_review" }
            ]}
          }
        },
        {
          "name": "Approve Loan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"approvedAmount\": 9500,\n  \"interestRate\": 8.99,\n  \"notes\": \"Good credit history, approved with standard rate\"\n}" },
            "url": "{{base}}/admin/loans/{{loanId}}/approve"
          }
        },
        {
          "name": "Decline Loan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"reason\": \"Debt-to-income ratio too high (48%). Maximum allowed is 43%.\"\n}" },
            "url": "{{base}}/admin/loans/{{loanId}}/decline"
          }
        },
        {
          "name": "Disburse Loan",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/loans/{{loanId}}/disburse"
          }
        },
        {
          "name": "Get All Loans (All Statuses)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/loans"
          }
        }
      ]
    },
    {
      "name": "06 🪪 KYC",
      "item": [
        {
          "name": "Get All KYC (Pending)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if(r.data?.kycs?.[0]?._id) pm.collectionVariables.set('kycId', r.data.kycs[0]._id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/admin/kyc?status=pending", "query": [
              { "key": "status", "value": "pending" }
            ]}
          }
        },
        {
          "name": "Get All KYC (All)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/kyc"
          }
        },
        {
          "name": "Approve KYC",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"approved\",\n  \"notes\": \"All documents verified. Identity confirmed.\"\n}" },
            "url": "{{base}}/admin/kyc/{{kycId}}/review"
          }
        },
        {
          "name": "Reject KYC",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"rejected\",\n  \"notes\": \"Document image is blurry. Please resubmit a clear photo.\"\n}" },
            "url": "{{base}}/admin/kyc/{{kycId}}/review"
          }
        },
        {
          "name": "Request KYC Resubmission",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"resubmit\",\n  \"notes\": \"Please provide a clearer selfie photo.\"\n}" },
            "url": "{{base}}/admin/kyc/{{kycId}}/review"
          }
        }
      ]
    },
    {
      "name": "07 📄 CHEQUES",
      "item": [
        {
          "name": "Get All Cheques (Submitted)",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if(r.data?.cheques?.[0]?._id) pm.collectionVariables.set('chequeId', r.data.cheques[0]._id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/admin/cheques?status=submitted", "query": [
              { "key": "status", "value": "submitted" }
            ]}
          }
        },
        {
          "name": "Accept Cheque",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"approved\"\n}" },
            "url": "{{base}}/admin/cheques/{{chequeId}}/review"
          }
        },
        {
          "name": "Decline Cheque",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"rejected\",\n  \"reason\": \"Cheque image is unclear. Signature does not match.\"\n}" },
            "url": "{{base}}/admin/cheques/{{chequeId}}/review"
          }
        }
      ]
    },
    {
      "name": "08 📈 INVESTMENTS",
      "item": [
        {
          "name": "Get All Investments",
          "event": [{ "listen": "test", "script": { "exec": [
            "const r = pm.response.json();",
            "if(r.data?.investments?.[0]?._id) pm.collectionVariables.set('investId', r.data.investments[0]._id);"
          ]}}],
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/investments"
          }
        },
        {
          "name": "Approve Investment",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"approved\"\n}" },
            "url": "{{base}}/admin/investments/{{investId}}/review"
          }
        },
        {
          "name": "Reject Investment (refunds user)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"decision\": \"rejected\",\n  \"reason\": \"Market closed. Order cannot be filled.\"\n}" },
            "url": "{{base}}/admin/investments/{{investId}}/review"
          }
        }
      ]
    },
    {
      "name": "09 ₿ CRYPTO ADDRESSES",
      "item": [
        {
          "name": "Get All Crypto Addresses",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/crypto/addresses"
          }
        },
        {
          "name": "Set Bitcoin Address",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"network\": \"BTC\",\n  \"address\": \"bc1qxy2kgdygjrsqtzq2n0yrf249abc123def456\",\n  \"label\": \"NexaBank Bitcoin Cold Wallet\",\n  \"minimumDeposit\": 0.0001,\n  \"confirmationsRequired\": 3,\n  \"isActive\": true\n}" },
            "url": "{{base}}/admin/crypto/addresses"
          }
        },
        {
          "name": "Set Ethereum Address",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"network\": \"ETH\",\n  \"address\": \"0x71C7656EC7ab88b098defB751B7401B5f6d8976F\",\n  \"label\": \"NexaBank Ethereum Wallet\",\n  \"minimumDeposit\": 0.01,\n  \"confirmationsRequired\": 12,\n  \"isActive\": true\n}" },
            "url": "{{base}}/admin/crypto/addresses"
          }
        },
        {
          "name": "Set USDT TRC20 (Tron) Address",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"network\": \"USDT_TRC20\",\n  \"address\": \"TJYeasTPa6gpEEfaFqzUHhMCFRMVFHqE5B\",\n  \"label\": \"NexaBank USDT TRC20 Wallet\",\n  \"minimumDeposit\": 10,\n  \"confirmationsRequired\": 19,\n  \"isActive\": true\n}" },
            "url": "{{base}}/admin/crypto/addresses"
          }
        },
        {
          "name": "Set USDT ERC20 Address",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"network\": \"USDT_ERC20\",\n  \"address\": \"0xdAC17F958D2ee523a2206206994597C13D831ec7\",\n  \"label\": \"NexaBank USDT ERC20 Wallet\",\n  \"minimumDeposit\": 10,\n  \"confirmationsRequired\": 12,\n  \"isActive\": true\n}" },
            "url": "{{base}}/admin/crypto/addresses"
          }
        },
        {
          "name": "Set Tron Address",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"network\": \"TRX\",\n  \"address\": \"TGj1Ej1qRzL9feLTLhjwgxXF4Ct6GTWg2U\",\n  \"label\": \"NexaBank Tron Wallet\",\n  \"minimumDeposit\": 100,\n  \"confirmationsRequired\": 19,\n  \"isActive\": true\n}" },
            "url": "{{base}}/admin/crypto/addresses"
          }
        },
        {
          "name": "Delete Crypto Address",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/crypto/addresses/BTC"
          }
        }
      ]
    },
    {
      "name": "10 🔔 OTP CONFIG",
      "item": [
        {
          "name": "Get All OTP Configs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{base}}/admin/otp/config"
          }
        },
        {
          "name": "Pause Transfer OTP",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"purpose\": \"transfer_confirmation\",\n  \"isEnabled\": false,\n  \"pausedReason\": \"Scheduled maintenance 02:00-04:00 EST\"\n}" },
            "url": "{{base}}/admin/otp/config"
          }
        },
        {
          "name": "Unpause Transfer OTP",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"purpose\": \"transfer_confirmation\",\n  \"isEnabled\": true\n}" },
            "url": "{{base}}/admin/otp/config"
          }
        },
        {
          "name": "Pause Login OTP",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"purpose\": \"login_verification\",\n  \"isEnabled\": false,\n  \"pausedReason\": \"OTP provider outage\"\n}" },
            "url": "{{base}}/admin/otp/config"
          }
        },
        {
          "name": "Update OTP Expiry and Attempts",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }, { "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"purpose\": \"email_verification\",\n  \"isEnabled\": true,\n  \"expiryMinutes\": 15,\n  \"maxAttempts\": 5\n}" },
            "url": "{{base}}/admin/otp/config"
          }
        }
      ]
    },
    {
      "name": "11 📝 AUDIT LOGS",
      "item": [
        {
          "name": "Get All Audit Logs",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": { "raw": "{{base}}/admin/logs?page=1&limit=50", "query": [
              { "key": "page",   "value": "1"  },
              { "key": "limit",  "value": "50" },
              { "key": "search", "value": "BLOCK_USER", "disabled": true },
              { "key": "from",   "value": "2024-01-01", "disabled": true },
              { "key": "to",     "value": "2024-12-31", "disabled": true }
            ]}
          }
        }
      ]
    }
  ]
}